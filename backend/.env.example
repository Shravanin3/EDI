# 1. Server Configuration
FLASK_ENV=development
FLASK_PORT=5000

# 2. Database Configuration (PostgreSQL)
# Format: postgresql://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql://postgres:your_local_password@localhost:5432/zero_trust_db

# 3. Authentication (Clerk Identity)
# Found in your Clerk Dashboard under "API Keys" -> "Secret Key"
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# 4. LLM & NLP Configuration
# The local model used by Paresh for zero-cost semantic intent matching
LOCAL_NLP_MODEL=all-MiniLM-L6-v2

# The Gemini API Key used by Prasanna to write friendly PR summaries
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# 5. GitHub Integration (Remediation Center)
# A GitHub Personal Access Token (PAT) with 'repo' scope to create branches and PRs
GITHUB_BOT_TOKEN=ghp_your_github_personal_access_token_here

# A random string you create to secure your webhook endpoint
GITHUB_WEBHOOK_SECRET=your_custom_random_secret_string